{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "test": "env-cmd -f .env-test ts-node -r tsconfig-paths/register node_modules/.bin/mocha \"./src/{,!(node_modules)/**}/*.test.ts\" --require source-map-support/register --recursive --exit",
    "dev": "concurrently \"tsc --watch --preserveWatchOutput\" \"nodemon -L --watch dist dist/server.js\"",
    "lint": "eslint . --ext ts,js --report-unused-disable-directives --max-warnings 0 && prettier --check .",
    "build": "npm run build-ts && npm run migrate",
    "env:check": "node dist/scripts/checkEnv.js",
    "build-ts": "tsc && cpy \"src/**/*.yaml\" dist && cpy \"src/**/*.md\" dist",
    "migrate": "ts-node -r tsconfig-paths/register ./node_modules/.bin/sequelize db:migrate",
    "migrate:test": "env-cmd -f .env-test ts-node -r tsconfig-paths/register ./node_modules/.bin/sequelize db:migrate",
    "migrate:all": "npm run migrate && npm run migrate:test",
    "prettier:write": "prettier --write .",
    "worker": "node dist/worker.js",
    "test:debug": "env-cmd -f .env-test node --inspect-brk=0.0.0.0:9229 node_modules/.bin/mocha \"./src/{,!(node_modules)/**}/*.test.ts\" --require ts-node/register --require source-map-support/register --recursive --exit --timeout 0",
    "worker:debug": "node --inspect-brk=0.0.0.0:9229 dist/worker.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "bullmq": "^5.70.1",
    "compression": "^1.8.0",
    "express": "^5.1.0",
    "express-bearer-token": "^3.0.0",
    "express-jwt": "^8.5.1",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "pg": "^8.15.6",
    "redoc-express": "^2.1.0",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.2",
    "source-map-support": "^0.5.21",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@faker-js/faker": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.5",
    "@types/chai": "^5.2.1",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "@types/sequelize": "^4.28.20",
    "@types/sinon": "^21.0.1",
    "@types/supertest": "^6.0.3",
    "chai": "^5.2.0",
    "concurrently": "^9.1.2",
    "cpy-cli": "^5.0.0",
    "env-cmd": "^10.1.0",
    "eslint": "^9.25.1",
    "mocha": "^11.1.0",
    "nock": "^14.0.11",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "sinon": "^21.1.0",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.31.1"
  },
  "engines": {
    "node": "22.15.0",
    "npm": "10.9.2"
  }
}
